# PSAU Management System - .gitignore

# Sensitive files
connect.php
**/connect.php

# Database files
database/
**/database/

# Upload folders
uploads/
**/uploads/

# Temporary files
*.tmp
*.temp

# Log files
*.log

# Environment files
.env
.env.local
.env.production

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# XAMPP specific
xampp/
htdocs/PSAU/.git/

# Backup files
*.bak
*.backup

# Cache
cache/
**/cache/

# Session files
sessions/
**/sessions/
